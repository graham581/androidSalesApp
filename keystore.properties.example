# Copy this file to `keystore.properties` (no `.example`) and fill in real
# values. The real `keystore.properties` is gitignored so credentials never
# land in source control. Both keystore + password must be backed up
# separately — losing either means you cannot publish updates to the same
# Google Play listing without going through Play App Signing key rotation.
#
# Forward slashes are fine in the path on Windows; backslashes need
# escaping ('C:\\Users\\...'). Easiest to use forward slashes.

SPARTAN_KEYSTORE_FILE=C:/Users/parrg/Documents/spartan-sales-upload.keystore
SPARTAN_KEYSTORE_PASSWORD=
SPARTAN_KEY_ALIAS=spartan-sales
SPARTAN_KEY_PASSWORD=
